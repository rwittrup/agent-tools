#!/usr/bin/env bash
# When commits touch agents/ or skills/, refresh home symlinks via sync script.
# If sync fails, the commit is aborted.

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

STAGED=$(git diff --cached --name-only || true)
[[ -n "$STAGED" ]] || exit 0

if ! printf '%s\n' "$STAGED" | grep -qE '^(agents/|skills/)'; then
  exit 0
fi

exec "$ROOT/sync-skills-and-agents.sh"
